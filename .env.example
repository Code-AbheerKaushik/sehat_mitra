# Required for the Next.js API routes deployed to Vercel.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Public OAuth client identifier (safe to expose to the browser).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional server-only key for Gemini-powered chat, tips, and diet plans.
GEMINI_API_KEY=your-gemini-api-key

# Optional external chat service. Leave blank to use the built-in offline responses.
NEXT_PUBLIC_CHAT_API_URL=https://your-chat-service.example.com/chat
